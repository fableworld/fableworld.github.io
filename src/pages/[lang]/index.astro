---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import FeatureSection from '../../components/FeatureSection.astro';
import Footer from '../../components/Footer.astro';
import { languages, ui, useTranslations } from '../../i18n/ui';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;

// Ensure lang is valid, though getStaticPaths handles it
const currentLang = (lang as keyof typeof ui) || 'en';
const t = useTranslations(currentLang);

const metaDescription = currentLang === 'it' 
  ? "Il portale per le tue storie Faba. Scopri OpenFable per i personaggi e FableForge per gestire il tuo dispositivo."
  : "The hub for your Faba stories. Discover OpenFable for characters and FableForge to manage your device.";
---

<Layout title="FableWorld - OpenFable & FableForge" description={metaDescription} lang={currentLang}>
  <Header lang={currentLang} />
  
  <main>
    <Hero t={t} />
    
    <!-- OpenFable Section -->
    <FeatureSection 
      id="openfable"
      title={t('openfable.title')}
      description={t('openfable.desc')}
      imageSrc="/openfable.png"
      features={[
        "Browse 100+ community characters",
        "Preview audio tracks directly",
        "Generate custom QR codes",
        "Mobile-friendly PWA"
      ]}
      ctaLink="https://openfable.d71.dev"
      ctaText="Explore OpenFable"
      gradientFrom="from-indigo-500"
      gradientTo="to-cyan-400"
      reverse={false}
    />

    <!-- FableForge Section -->
    <FeatureSection 
      id="fableforge"
      title={t('fableforge.title')}
      description={t('fableforge.desc')}
      imageSrc="/fableforge.png"
      features={[
        "Drag & Drop track management",
        "Automatic file conversion",
        "Complete device backup/restore",
        "Cross-platform (Windows, macOS, Linux)"
      ]}
      ctaLink="https://github.com/fableworld/fableforge"
      ctaText="Download on GitHub"
      gradientFrom="from-purple-600"
      gradientTo="to-indigo-600"
      reverse={true}
    />
  </main>

  <Footer />
</Layout>