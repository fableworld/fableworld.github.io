---
import { languages } from '../i18n/ui';

interface Props {
  lang: keyof typeof languages;
}

const { lang } = Astro.props;

const navLinks = [
  { href: `/${lang}/`, labelKey: 'nav.home' },
  { href: '#openfable', labelKey: 'nav.openfable' },
  { href: '#fableforge', labelKey: 'nav.fableforge' },
];
---

<header class="fixed top-0 z-50 w-full border-b border-white/10 bg-slate-950/50 backdrop-blur-xl">
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
    <div class="flex items-center gap-2">
      <div class="h-8 w-8 rounded-lg bg-gradient-to-br from-primary-500 to-indigo-600 shadow-lg shadow-primary-500/20"></div>
      <span class="text-xl font-bold font-display tracking-tight text-white">FableWorld</span>
    </div>
    
    <nav class="hidden md:flex gap-6">
      <a href={`/${lang}/`} class="text-sm font-medium text-slate-300 hover:text-white transition-colors">Home</a>
      <a href="#openfable" class="text-sm font-medium text-slate-300 hover:text-primary-400 transition-colors">OpenFable</a>
      <a href="#fableforge" class="text-sm font-medium text-slate-300 hover:text-primary-400 transition-colors">FableForge</a>
    </nav>

    <div class="flex items-center gap-4">
      <div class="relative group">
        <button class="text-sm font-medium text-slate-300 hover:text-white flex items-center gap-1">
          {languages[lang]}
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-down"><path d="m6 9 6 6 6-6"/></svg>
        </button>
        <div class="absolute right-0 mt-2 w-32 origin-top-right rounded-md bg-slate-800 shadow-lg ring-1 ring-black ring-opacity-5 focus:outline-none hidden group-hover:block animate-in fade-in slide-in-from-top-2 duration-200">
          <div class="py-1">
            {Object.entries(languages).map(([l, label]) => (
              <a href={`/${l}/`} class="block px-4 py-2 text-sm text-slate-300 hover:bg-slate-700 hover:text-white">
                {label}
              </a>
            ))}
          </div>
        </div>
      </div>
      <a href="https://github.com/fableworld" target="_blank" rel="noopener noreferrer" class="hidden sm:block text-slate-400 hover:text-white transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-github"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
      </a>
    </div>
  </div>
</header>